# ============================================================
# Server
# ============================================================
# Affects only the `app` logger tree. uvicorn's own access/error loggers
# follow uvicorn's own --log-level (set in Dockerfile CMD if needed).
LOG_LEVEL=INFO
# Public base URL of THIS gateway (used to build Alipay/WeChat notify URLs).
# MUST be HTTPS in production. Note: HOST/PORT are NOT env-configurable —
# uvicorn binds via Dockerfile CMD; edit there if you need different ones.
GATEWAY_PUBLIC_URL=https://pay.example.com

# ============================================================
# epay protocol (gateway <-> new-api)
# Configure the SAME values in new-api admin: PayAddress=GATEWAY_PUBLIC_URL,
# EpayId=EPAY_PID, EpayKey=EPAY_KEY.
# ============================================================
EPAY_PID=1000
# 32+ bytes random string. Generate: openssl rand -hex 32
EPAY_KEY=CHANGE_ME_to_a_long_random_string
# new-api's epay notify endpoint (fixed for single-tenant deployment).
NEW_API_NOTIFY_URL=https://api.example.com/api/user/epay/notify
# Timeout (seconds) when calling new-api's notify endpoint.
NEW_API_NOTIFY_TIMEOUT=5.0

# ============================================================
# attach HMAC secret (used to sign money inside passback_params/attach)
# Independent of EPAY_KEY. Generate: openssl rand -hex 32
# ============================================================
ATTACH_HMAC_KEY=CHANGE_ME_to_another_long_random_string

# ============================================================
# Alipay (PC web pay)
# ============================================================
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
# Path to PEM file (PKCS#1 or PKCS#8). Mount as docker secret in production.
ALIPAY_APP_PRIVATE_KEY_PATH=/run/secrets/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/run/secrets/alipay_public_key.pem
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_SANDBOX=false

# ============================================================
# WeChat Pay v3 (Native scan-to-pay)
# ============================================================
WECHAT_ENABLED=false
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_MCH_CERT_SERIAL_NO=
WECHAT_MCH_PRIVATE_KEY_PATH=/run/secrets/wechat_mch_private_key.pem
WECHAT_APIV3_KEY=
# Directory to cache platform certs (auto-rotated). On first start the SDK
# fetches certs from api.mch.weixin.qq.com — startup will fail if the host
# can't reach WeChat at that moment. Set this to a persistent volume so
# subsequent starts work offline. Leave empty to use a temp dir (re-fetch
# on every start, fragile).
WECHAT_CERT_DIR=/run/secrets/wechat_certs
# Timeouts (seconds) for SDK calls to api.mch.weixin.qq.com. Critical:
# leaving these unset would let a WeChat outage pin every asyncio executor
# thread (default 8-32 per CPU) and freeze the gateway.
WECHAT_CONNECT_TIMEOUT=5.0
WECHAT_READ_TIMEOUT=30.0

# ============================================================
# Security / hardening
# ============================================================
# requests/minute per client IP for /submit.php
RATE_LIMIT_PER_MINUTE=60
# Max request body size (bytes). epay submit is tiny.
MAX_REQUEST_BYTES=8192
